# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# Backend
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=remote_assignment;Username=postgres;Password=change-me;SSL Mode=Prefer;Trust Server Certificate=true

# Supabase placeholders
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-with-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Security placeholders for later phases
JWT_ISSUER=remote-assignment
JWT_AUDIENCE=remote-assignment-users
JWT_SIGNING_KEY=replace-with-a-long-random-secret
Auth__Issuer=remote-assignment
Auth__Audience=remote-assignment-users
Auth__SigningKey=replace-with-a-long-random-secret-at-least-32-characters
Auth__RefreshTokenDays=14
Auth__Bootstrap__Enabled=false
Auth__Bootstrap__Password=ChangeMe123!
